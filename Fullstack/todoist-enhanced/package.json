{
  "name": "todoist-enhanced",
  "version": "1.0.0",
  "description": "Todoist Enhanced Clone - 150 features, React+Node+SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm run build",
    "dev:full": "concurrently \"nodemon server.js\" \"cd client && npm run dev\"",
    "lint": "eslint server.js routes/**/*.js middleware/**/*.js utils/**/*.js"
  },
  "keywords": [
    "todoist",
    "tasks",
    "productivity",
    "sqlite"
  ],
  "author": "Michaelunkai",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "serverless-http": "^3.2.0",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "nodemon": "^3.0.3"
  }
}
